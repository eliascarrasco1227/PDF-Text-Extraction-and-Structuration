                    <form>ule</form>
                    <gloss>ule</gloss>
                </unit>
                <unit>
                    <form>tej</form>
                    <gloss>tej</gloss>
                </unit>
                <unit>
                    <form>ttzaj</form>
                    <gloss>ttzaj</gloss>
                </unit>
                <unit>
                    <form>jb'al.</form>
                    <gloss>jb'al.</gloss>
                </unit>
            </morpheme_analysis>
        </interlinear_gloss>
        <interlinear_gloss>
            <parallel_phrase>
                <original>Otaq qo wane tej tula.</original>
                <translation>Ya habíamos venido cuando veniste.</translation>
            </parallel_phrase>
            <morpheme_analysis>
                <unit>
                    <form>otaq</form>
                    <gloss>Otaq</gloss>
