            </morpheme_analysis>
        </interlinear_gloss>
        <interlinear_gloss>
            <parallel_phrase>
                <original>Ojetaq jawul twi' nkojine tej npone.</original>
                <translation>Ya había germinado mi milpa cuando llegué.</translation>
            </parallel_phrase>
